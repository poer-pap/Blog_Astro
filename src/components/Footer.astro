---
import { getSiteConfig } from '../data/site';

const today = new Date();
const { site } = await getSiteConfig();
---

<footer>
  &copy; {today.getFullYear()}
  {site.title}. {site.footerNote}
</footer>
<style>
  footer {
    padding: 3em 1em 6em;
    color: var(--paper-ink-faint);
    font-size: 0.88rem;
    text-align: center;
  }
</style>
